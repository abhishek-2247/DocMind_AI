# ============================================================
# DocMind AI — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# ============================================================

# Flask
SECRET_KEY=your-very-secret-flask-key-change-this
FLASK_ENV=production
FLASK_DEBUG=0

# Database
# SQLite — LOCAL development (relative path, stored in instance/):
DATABASE_URL=sqlite:///docmind.db
#
# SQLite — RENDER / Heroku (only /tmp is writable — use 4 slashes for absolute path):
# DATABASE_URL=sqlite:////tmp/docmind.db
#
# PostgreSQL (Railway / Render / Heroku — recommended for production persistence):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Note: Heroku provides 'postgres://' — the app auto-corrects this to 'postgresql://'

# IBM watsonx.ai credentials
IBM_API_KEY=your-ibm-cloud-api-key-here
IBM_PROJECT_ID=your-watsonx-project-id-here
# Region URL — match your WML service region:
# US Dallas:    https://us-south.ml.cloud.ibm.com
# EU London:    https://eu-gb.ml.cloud.ibm.com
# EU Frankfurt: https://eu-de.ml.cloud.ibm.com
# Tokyo:        https://jp-tok.ml.cloud.ibm.com
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# File uploads
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216   # 16 MB in bytes
ALLOWED_EXTENSIONS=pdf,docx,pptx,txt

# Rate limiting (optional — uses in-memory by default)
# For production with multiple workers, provide a Redis URL:
# REDIS_URL=redis://localhost:6379/0
