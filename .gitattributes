# Normalise all text files to LF in the repository.
# Windows checkouts will still use CRLF locally if core.autocrlf is true.
* text=auto eol=lf
*.py   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.env.example text eol=lf
Procfile text eol=lf
